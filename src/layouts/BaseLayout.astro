---
import "~/styles/global.css";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";
import SeoMeta from "~/components/SeoMeta.astro";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  structuredData?:
    | Record<string, unknown>
    | Record<string, unknown>[]
    | null;
  bodyClass?: string;
}

const {
  title,
  description,
  canonical,
  ogImage,
  noindex = false,
  structuredData = null,
  bodyClass = "",
} = Astro.props;

// Global schema present on every page. Anchors the entity for AI search
// engines and helps build knowledge-graph confidence in the brand.
const ORG_SCHEMA: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://storeauditor.au/#organization",
  name: "Store Auditor",
  url: "https://storeauditor.au",
  logo: {
    "@type": "ImageObject",
    url: "https://storeauditor.au/apple-touch-icon.png",
  },
  description:
    "Shopify performance audit app that attributes blocking time to specific named installed apps. Built by Defyn Digital.",
  sameAs: [
    "https://apps.shopify.com/store-auditor",
    "https://github.com/Defyn-Digital/store-auditor-site",
    "https://defyn.com.au",
    "https://www.wikidata.org/wiki/Q140048279",
  ],
  parentOrganization: {
    "@type": "Organization",
    name: "Defyn Digital",
    url: "https://defyn.com.au",
    sameAs: ["https://www.wikidata.org/wiki/Q140047522"],
  },
};

const SITE_SCHEMA: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://storeauditor.au/#website",
  name: "Store Auditor",
  alternateName: "storeauditor.au",
  url: "https://storeauditor.au",
  inLanguage: "en-AU",
  publisher: { "@id": "https://storeauditor.au/#organization" },
};

const perPage: Record<string, unknown>[] = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];

const allStructuredData: Record<string, unknown>[] = [
  ORG_SCHEMA,
  SITE_SCHEMA,
  ...perPage,
];
---

<!doctype html>
<html lang="en-AU">
  <head>
    {/* Google Tag Manager — must be high in <head> for the most accurate measurement. */}
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-ML4VPHPB');
    </script>
    {/* End Google Tag Manager */}

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0B1220" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link
      rel="preconnect"
      href="https://rsms.me/"
      crossorigin
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Store Auditor Insights"
      href="/rss.xml"
    />
    <SeoMeta
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      noindex={noindex}
      structuredData={allStructuredData}
    />

    <!-- DefynCow embed — conversion popout. Workspace token is public-safe -->
    <!-- (only authorises the visitor to fetch active campaign config). -->
    <script async data-defyncow="kotVdLex1V69Rn1AL2GRZlQHnT1nGb7URArgyB9oMRADNyhYz92rSMPhwfFKOvB8k5pDww9YIkY2ceLm" src="https://defyncow.vercel.app/embed.js"></script>
  </head>
  <body class:list={["grain", bodyClass]}>
    {/* Google Tag Manager (noscript) — required fallback for users with JS disabled. */}
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-ML4VPHPB"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe></noscript
    >
    {/* End Google Tag Manager (noscript) */}

    <a href="#main" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <style>
      .skip-link {
        position: absolute;
        top: -40px;
        left: 1rem;
        background: var(--accent);
        color: #1f1300;
        padding: 0.5rem 1rem;
        border-radius: var(--radius-sm);
        font-weight: 600;
        z-index: 100;
        transition: top var(--dur-fast) var(--ease);
      }
      .skip-link:focus {
        top: 1rem;
      }
    </style>
  </body>
</html>
