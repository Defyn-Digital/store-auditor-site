---
/*
  Sample per-app impact table — the visual hook that demonstrates the
  "names every app on your storefront" promise. Static demo data — same
  apps as the in-product seeded demo so the brand stays consistent.
*/
const rows = [
  { name: "Klaviyo Email Marketing", category: "Marketing", blocking: "680ms", severity: "Critical", severityClass: "critical" },
  { name: "Google Analytics 4", category: "Analytics", blocking: "540ms", severity: "Critical", severityClass: "critical" },
  { name: "Judge.me Product Reviews", category: "Reviews", blocking: "360ms", severity: "High", severityClass: "high" },
  { name: "Meta Pixel", category: "Analytics", blocking: "220ms", severity: "High", severityClass: "high" },
  { name: "Tidio Live Chat", category: "Support", blocking: "170ms", severity: "Medium", severityClass: "medium" },
  { name: "Hotjar Session Replay", category: "Analytics", blocking: "155ms", severity: "Medium", severityClass: "medium" },
];
---

<div class="applist-card">
  <header class="applist-header">
    <div>
      <p class="applist-label">Per-app impact · sample audit</p>
      <h3 class="applist-title">8 apps detected on storefront</h3>
    </div>
    <div class="applist-meta">
      <span class="meta-dot"></span>
      Scanned 4 min ago
    </div>
  </header>

  <div class="applist-table">
    <div class="applist-row applist-row-head">
      <span>App</span>
      <span class="hide-sm">Category</span>
      <span>Blocking time</span>
      <span>Severity</span>
    </div>
    {
      rows.map((row) => (
        <div class="applist-row">
          <span class="app-name">{row.name}</span>
          <span class="hide-sm muted">{row.category}</span>
          <span class="mono">{row.blocking}</span>
          <span class:list={["sev", `sev-${row.severityClass}`]}>
            {row.severity}
          </span>
        </div>
      ))
    }
  </div>

  <p class="applist-footnote muted">
    Sample data shown. Your audit reflects your store's actual installed apps.
  </p>
</div>

<style>
  .applist-card {
    background: var(--bg-card);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
    padding: var(--space-32);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.03) inset,
      0 24px 64px -32px rgba(0, 0, 0, 0.6);
  }

  .applist-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-16);
    margin-bottom: var(--space-24);
  }

  .applist-label {
    font-size: var(--fs-12);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: 0.375rem;
  }

  .applist-title {
    font-size: var(--fs-20);
    font-weight: 600;
    letter-spacing: -0.012em;
  }

  .applist-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--fs-12);
    color: var(--text-tertiary);
    flex-shrink: 0;
  }

  .meta-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.15);
  }

  .applist-table {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--border-soft);
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--border-soft);
  }

  .applist-row {
    display: grid;
    grid-template-columns: 2.4fr 1fr 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
    padding: 0.875rem 1.125rem;
    background: var(--bg-card);
    font-size: var(--fs-14);
  }

  .applist-row-head {
    background: rgba(255, 255, 255, 0.025);
    font-size: var(--fs-12);
    color: var(--text-tertiary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .app-name {
    font-weight: 500;
    color: var(--text);
  }

  .mono {
    font-family: var(--font-mono);
    color: var(--text-secondary);
  }

  .sev {
    justify-self: start;
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-full);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .sev-critical {
    background: var(--danger-soft);
    color: #fca5a5;
  }

  .sev-high {
    background: var(--accent-soft);
    color: #fbbf24;
  }

  .sev-medium {
    background: rgba(99, 102, 241, 0.14);
    color: #a5b4fc;
  }

  .applist-footnote {
    font-size: var(--fs-12);
    margin-top: var(--space-16);
  }

  @media (max-width: 640px) {
    .applist-row {
      grid-template-columns: 2fr 1fr 1fr;
    }
    .hide-sm {
      display: none;
    }
  }
</style>
