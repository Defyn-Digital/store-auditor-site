---
/*
  The signature spike-waveform used throughout the brand. Used as a hero
  decoration. preserveAspectRatio="none" lets it scale fluidly while keeping
  the spike crisp.
*/
interface Props {
  width?: string;
  height?: string;
  className?: string;
}
const { width = "100%", height = "100%", className } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 1200 320"
  width={width}
  height={height}
  class={className}
  aria-hidden="true"
  preserveAspectRatio="xMidYMid meet"
>
  <!-- Baseline grid -->
  <line
    x1="40"
    y1="140"
    x2="1160"
    y2="140"
    stroke="#E5E7EB"
    stroke-opacity="0.07"
    stroke-width="1.5"></line>
  <line
    x1="40"
    y1="220"
    x2="1160"
    y2="220"
    stroke="#E5E7EB"
    stroke-opacity="0.07"
    stroke-width="1.5"></line>

  <!-- Pre-spike calm baseline -->
  <path
    d="M 40 180 L 220 180 L 280 168 L 340 192 L 420 174 L 510 188 L 590 172 L 660 184"
    fill="none"
    stroke="#CBD5E1"
    stroke-opacity="0.5"
    stroke-width="5"
    stroke-linecap="round"
    stroke-linejoin="round"></path>

  <!-- The spike — accent orange -->
  <path
    d="M 660 184 L 720 60 L 780 280 L 840 184"
    fill="none"
    stroke="#F59E0B"
    stroke-width="8"
    stroke-linecap="round"
    stroke-linejoin="round"></path>

  <!-- Post-spike calm baseline -->
  <path
    d="M 840 184 L 900 180 L 980 186 L 1060 178 L 1140 184"
    fill="none"
    stroke="#CBD5E1"
    stroke-opacity="0.5"
    stroke-width="5"
    stroke-linecap="round"
    stroke-linejoin="round"></path>

  <!-- Spike annotation marker -->
  <circle cx="720" cy="60" r="6" fill="#F59E0B"></circle>
  <line
    x1="720"
    y1="60"
    x2="720"
    y2="30"
    stroke="#F59E0B"
    stroke-opacity="0.6"
    stroke-width="1.5"></line>
</svg>
