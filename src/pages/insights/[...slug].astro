---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import CtaBlock from "~/components/CtaBlock.astro";

export async function getStaticPaths() {
  const posts = await getCollection("insights", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"insights">;
}

const { post } = Astro.props;
const { Content } = await post.render();
const { data } = post;

const publishedISO = data.publishedDate.toISOString();
const updatedISO = (data.updatedDate ?? data.publishedDate).toISOString();
const formatDate = (d: Date) =>
  d.toLocaleDateString("en-AU", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });

const url = `https://storeauditor.au/insights/${post.slug}`;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: data.title,
  description: data.description,
  url,
  mainEntityOfPage: url,
  datePublished: publishedISO,
  dateModified: updatedISO,
  inLanguage: "en-AU",
  keywords: [data.primaryKeyword, ...(data.secondaryKeywords ?? [])].join(", "),
  author: {
    "@type": "Organization",
    name: "Defyn Digital",
    url: "https://defyn.com.au",
  },
  publisher: {
    "@type": "Organization",
    name: "Store Auditor",
    url: "https://storeauditor.au",
    logo: {
      "@type": "ImageObject",
      url: "https://storeauditor.au/apple-touch-icon.png",
    },
  },
};

// Pull 3 related posts (same category, exclude self)
const allPosts = await getCollection("insights", ({ data }) => !data.draft);
const related = allPosts
  .filter((p) => p.slug !== post.slug && p.data.category === data.category)
  .sort(
    (a, b) =>
      new Date(b.data.publishedDate).getTime() -
      new Date(a.data.publishedDate).getTime()
  )
  .slice(0, 3);
---

<BaseLayout
  title={`${data.title} | Store Auditor`}
  description={data.description}
  canonical={url}
  structuredData={articleSchema}
>
  <article class="post">
    <header class="post-header">
      <div class="container container-prose">
        <p class="eyebrow">
          <a href="/insights" class="back-link">Insights</a>
          <span class="sep" aria-hidden="true">/</span>
          <span class:list={["category", `category-${data.category}`]}>
            {data.category}
          </span>
        </p>

        <h1 class="post-title">{data.title}</h1>

        <p class="post-meta">
          {formatDate(data.publishedDate)}
          <span class="sep" aria-hidden="true">·</span>
          {data.readingTime} min read
          <span class="sep" aria-hidden="true">·</span>
          By <a href="https://defyn.com.au" rel="noopener">Defyn Digital</a>
        </p>
      </div>
    </header>

    <div class="container container-prose post-body">
      <Content />
    </div>

    <div class="container container-prose">
      <aside class="author-card">
        <p class="author-label">About the author</p>
        <p>
          <strong>Defyn Digital</strong> is a Sydney-based Shopify
          development agency. We built Store Auditor because we got tired
          of running per-app performance audits by hand for our agency
          clients. Find more guides on the
          <a href="/insights">Insights page</a>, or read
          <a href="/how-it-works">how Store Auditor's audit works</a>.
        </p>
        <p>
          <a href="https://defyn.com.au" rel="noopener">defyn.com.au</a>
          <span class="sep" aria-hidden="true">·</span>
          <a href="https://apps.shopify.com/store-auditor">
            Install Store Auditor
          </a>
        </p>
      </aside>

      {
        related.length > 0 && (
          <section class="related">
            <h2 class="related-heading">More from Insights</h2>
            <div class="related-grid">
              {related.map((p) => (
                <a class="related-card" href={`/insights/${p.slug}`}>
                  <span class:list={["category", `category-${p.data.category}`]}>
                    {p.data.category}
                  </span>
                  <h3>{p.data.title}</h3>
                  <p>{p.data.description}</p>
                </a>
              ))}
            </div>
          </section>
        )
      }
    </div>
  </article>

  <CtaBlock
    eyebrow="Run an audit"
    heading="See the same analysis on your own store."
    description="Install Store Auditor free. Get a per-app audit of your Shopify storefront in 90 seconds, no theme edits, no separate account."
    secondaryLabel="Read more guides"
    secondaryUrl="/insights"
  />
</BaseLayout>

<style>
  .post-header {
    padding-block: clamp(3rem, 6vw, 5rem) clamp(2rem, 4vw, 3rem);
  }

  .post-header .eyebrow {
    margin-bottom: var(--space-24);
    color: var(--text-tertiary);
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    text-transform: none;
    letter-spacing: 0;
    font-size: var(--fs-14);
    font-weight: 500;
  }

  /* Override eyebrow's default green dot for breadcrumbs */
  .post-header .eyebrow::before {
    display: none;
  }

  .back-link {
    color: var(--text-secondary);
    transition: color var(--dur-fast) var(--ease);
  }
  .back-link:hover { color: var(--text); }

  .sep {
    color: var(--text-quaternary);
  }

  .category {
    display: inline-flex;
    padding: 0.18rem 0.625rem;
    border-radius: var(--radius-full);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .category-performance { background: var(--accent-soft); color: #fbbf24; }
  .category-security { background: rgba(99, 102, 241, 0.14); color: #a5b4fc; }
  .category-general { background: var(--success-soft); color: var(--success); }

  .post-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--text);
    max-width: 22ch;
  }

  .post-meta {
    margin-top: var(--space-24);
    padding-top: var(--space-16);
    border-top: 1px solid var(--border-soft);
    color: var(--text-tertiary);
    font-size: var(--fs-14);
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
  }

  .post-meta a {
    color: var(--text);
    text-decoration: underline;
    text-decoration-color: var(--border);
    text-underline-offset: 3px;
  }
  .post-meta a:hover { text-decoration-color: var(--accent); }

  .post-body {
    color: var(--text-secondary);
    font-size: var(--fs-18);
    line-height: 1.7;
    padding-bottom: var(--space-48);
  }

  /* Markdown content styling */
  .post-body :global(h2) {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    margin-top: var(--space-48);
    margin-bottom: var(--space-16);
    scroll-margin-top: 80px;
  }

  .post-body :global(h3) {
    font-size: var(--fs-20);
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.012em;
    margin-top: var(--space-32);
    margin-bottom: var(--space-12);
  }

  .post-body :global(p) {
    margin-bottom: var(--space-16);
    max-width: 64ch;
  }

  .post-body :global(p strong),
  .post-body :global(li strong) {
    color: var(--text);
    font-weight: 600;
  }

  .post-body :global(em) {
    color: var(--text);
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin-left: 1.25rem;
    margin-bottom: var(--space-24);
    max-width: 64ch;
  }

  .post-body :global(li) {
    margin-bottom: 0.5rem;
  }

  .post-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.92em;
    background: rgba(255, 255, 255, 0.06);
    padding: 0.1em 0.35em;
    border-radius: 4px;
    color: #fbbf24;
  }

  .post-body :global(pre) {
    background: var(--bg-card);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-md);
    padding: var(--space-20);
    overflow-x: auto;
    margin-bottom: var(--space-24);
    font-size: var(--fs-14);
    line-height: 1.55;
  }

  .post-body :global(pre code) {
    background: none;
    padding: 0;
    color: var(--text-secondary);
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: var(--space-20);
    margin-block: var(--space-24);
    color: var(--text);
    font-style: italic;
  }

  .post-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: var(--accent-soft);
    text-underline-offset: 3px;
    transition: text-decoration-color var(--dur-fast) var(--ease);
  }

  .post-body :global(a:hover) {
    text-decoration-color: var(--accent);
  }

  .post-body :global(img) {
    margin-block: var(--space-24);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-soft);
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border-soft);
    margin-block: var(--space-48);
  }

  .post-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-block: var(--space-24);
    font-size: var(--fs-14);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .post-body :global(th),
  .post-body :global(td) {
    text-align: left;
    padding: var(--space-12) var(--space-16);
    border-bottom: 1px solid var(--border-soft);
  }

  .post-body :global(th) {
    background: rgba(255, 255, 255, 0.02);
    color: var(--text-tertiary);
    text-transform: uppercase;
    font-size: var(--fs-12);
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  .post-body :global(tr:last-child td) {
    border-bottom: none;
  }

  /* Author card */
  .author-card {
    background: var(--bg-card);
    border: 1px solid var(--border-soft);
    border-left: 3px solid var(--success);
    border-radius: var(--radius-lg);
    padding: var(--space-32);
    margin-bottom: var(--space-48);
  }

  .author-label {
    font-size: var(--fs-12);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--success);
    font-weight: 700;
    margin-bottom: var(--space-16);
  }

  .author-card p {
    font-size: var(--fs-16);
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-12);
  }

  .author-card p:last-child { margin-bottom: 0; }

  .author-card a {
    color: var(--text);
    text-decoration: underline;
    text-decoration-color: var(--border);
    text-underline-offset: 3px;
  }
  .author-card a:hover { text-decoration-color: var(--accent); }

  /* Related */
  .related {
    margin-block: var(--space-64) var(--space-32);
  }

  .related-heading {
    font-size: var(--fs-24);
    font-weight: 700;
    letter-spacing: -0.012em;
    margin-bottom: var(--space-24);
    color: var(--text);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-16);
  }

  .related-card {
    background: var(--bg-card);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
    padding: var(--space-24);
    color: var(--text);
    transition: border-color var(--dur-fast) var(--ease);
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .related-card:hover { border-color: var(--accent); }

  .related-card h3 {
    font-size: var(--fs-18);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.012em;
    color: var(--text);
  }

  .related-card p {
    font-size: var(--fs-14);
    color: var(--text-secondary);
    line-height: 1.5;
  }

  @media (max-width: 720px) {
    .related-grid { grid-template-columns: 1fr; }
  }
</style>
